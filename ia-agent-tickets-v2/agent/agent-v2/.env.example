# ── LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# ── Backend adapter
# express=local dev | http=Odoo REST API | postgres=future
BACKEND_ADAPTER=express
BACKEND_URL=http://localhost:3001
ODOO_BASE_URL=
ODOO_API_KEY=
ODOO_DATABASE=

# ── RAG
VECTOR_STORE_PATH=./vector_store
RAG_ENABLED=true
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.6

# ── Auth (header: X-Agent-Key)
# Generate strong key: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_API_KEY=dev-key-change-in-prod

# ── Conversation persistence (memory=dev | sqlite=prod)
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_DB_PATH=./checkpoints.db

# ── AI feedback (NOT ticket CSAT)
FEEDBACK_DB_PATH=./feedback.db

# ── Server (port 8001 - v1 uses 8000)
PORT=8001
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
